# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic Configuration (Optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini Configuration (Optional)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-pro

# Ollama Local LLM Configuration (Optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# LM Studio Configuration (Optional)
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=local-model

# Custom Local LLM Configuration (Optional)
CUSTOM_LLM_BASE_URL=http://localhost:8080
CUSTOM_LLM_MODEL=custom-model
CUSTOM_LLM_API_KEY=your_custom_llm_key_here

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Leave blank for local dev only; REQUIRED in production.
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# RabbitMQ Configuration — REQUIRED (no fallback defaults in docker-compose)
# Use strong, unique credentials. "guest" is NOT accepted in production.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=qa_user
RABBITMQ_PASSWORD=change_me_strong_password
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://qa_user:change_me_strong_password@rabbitmq:5672/

# WebGUI Configuration
WEBGUI_HOST=0.0.0.0
WEBGUI_PORT=8000
LOG_LEVEL=INFO
# Set to "production" to enable stricter security checks
ENVIRONMENT=development

# Authentication (required for production)
WEBGUI_SECRET_KEY=
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=
OAUTH2_AZURE_CLIENT_ID=

# Machine-to-machine API key (static; for simple single-key deployments)
# Use POST /api/auth/api-keys for per-client Redis-backed keys instead.
AGNOSTIC_API_KEY=

# CORS — comma-separated list of allowed origins for browser clients
CORS_ALLOWED_ORIGINS=http://localhost:18789,http://localhost:3001

# Real-time Features
WEBSOCKET_ENABLED=true
REDIS_PUBSUB_CHANNEL=webgui_updates

# Reporting
REPORT_EXPORT_PATH=/app/reports
PDF_GENERATOR_ENGINE=reportlab

# Scheduled Reports
SCHEDULED_REPORTS_ENABLED=false
SCHEDULED_REPORT_DAILY_TIME=09:00
SCHEDULED_REPORT_WEEKLY_DAY=monday
SCHEDULED_REPORT_WEEKLY_TIME=09:00
REDIS_SCHEDULER_DB=1
REPORT_WEBHOOK_URL=                  # Webhook URL for report delivery notifications
REPORT_WEBHOOK_SECRET=               # HMAC-SHA256 secret for webhook signatures
REPORT_SLACK_WEBHOOK_URL=            # Slack incoming webhook for report notifications
REPORT_DELIVERY_MAX_RETRIES=3        # Retry attempts for delivery channels

# WebSocket / Real-time
REALTIME_STREAM_MAX_LEN=1000         # Max messages per Redis Stream (message buffer)
REALTIME_STREAM_REPLAY_LIMIT=100     # Max messages replayed on reconnection

# Database (PostgreSQL)
DATABASE_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=agnostic

# Multi-Tenant
MULTI_TENANT_ENABLED=false
TENANT_DEFAULT_RATE_LIMIT=100        # Requests per minute per tenant

# AGNOS OS Integration
# Phase 1: LLM Gateway (see ADR-021)
AGNOS_LLM_GATEWAY_ENABLED=false
AGNOS_LLM_GATEWAY_URL=http://localhost:8088
AGNOS_LLM_GATEWAY_API_KEY=
AGNOS_LLM_GATEWAY_MODEL=default

# Phase 2: Agent HUD Registration (see ADR-022)
AGNOS_AGENT_REGISTRATION_ENABLED=false
AGNOS_AGENT_REGISTRY_URL=http://localhost:8090
AGNOS_AGENT_API_KEY=

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Redis Connection Pool
REDIS_MAX_CONNECTIONS=50

# Advanced Features
ENABLE_SELF_HEALING=true
ENABLE_FUZZY_VERIFICATION=true
ENABLE_RISK_BASED_PRIORITIZATION=true
ENABLE_CONTEXT_AWARE_TESTING=true

# AGNOS OS Integration (optional — enables routing through agnosticos LLM Gateway)
# Set AGNOS_LLM_GATEWAY_ENABLED=true when running Agnostic on or alongside AGNOS OS.
# The AGNOS LLM Gateway (agnosticos/userland/llm-gateway) exposes an OpenAI-compatible
# REST API at port 8088 and adds per-agent token accounting, rate limiting, and caching.
AGNOS_LLM_GATEWAY_ENABLED=false
AGNOS_LLM_GATEWAY_URL=http://localhost:8088
AGNOS_LLM_GATEWAY_API_KEY=
AGNOS_LLM_GATEWAY_MODEL=default

# Model Selection
PRIMARY_MODEL_PROVIDER=openai
FALLBACK_MODEL_PROVIDERS=ollama

# Team Configuration
QA_TEAM_SIZE=standard
