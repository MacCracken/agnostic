# Backend Selection
# "crewai" (default) — Python/CrewAI local execution
# "agnosai" — Rust-native AgnosAI server via HTTP
AGNOSTIC_BACKEND=crewai
AGNOSAI_URL=http://localhost:8080
AGNOSAI_API_KEY=

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic Configuration (Optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini Configuration (Optional)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-pro

# Ollama Local LLM Configuration (Optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# LM Studio Configuration (Optional)
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=local-model

# Custom Local LLM Configuration (Optional)
CUSTOM_LLM_BASE_URL=http://localhost:8080
CUSTOM_LLM_MODEL=custom-model
CUSTOM_LLM_API_KEY=your_custom_llm_key_here

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Leave blank for local dev only; REQUIRED in production.
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# RabbitMQ Configuration — REQUIRED (no fallback defaults in docker-compose)
# Use strong, unique credentials. "guest" is NOT accepted in production.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=qa_user
RABBITMQ_PASSWORD=change_me_strong_password
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://qa_user:change_me_strong_password@rabbitmq:5672/

# WebGUI Configuration
WEBGUI_HOST=0.0.0.0
WEBGUI_PORT=8000
LOG_LEVEL=INFO

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=INFO

# Set to "production" to enable stricter security checks
ENVIRONMENT=development

# Authentication (required for production)
WEBGUI_SECRET_KEY=
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=
OAUTH2_AZURE_CLIENT_ID=
OAUTH2_AZURE_TENANT_ID=

# Login rate limiting
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW=300

# Machine-to-machine API key (static; for simple single-key deployments)
# Use POST /api/auth/api-keys for per-client Redis-backed keys instead.
AGNOSTIC_API_KEY=

# CORS — comma-separated list of allowed origins for browser clients
CORS_ALLOWED_ORIGINS=http://localhost:18789,http://localhost:3001

# Real-time Features
WEBSOCKET_ENABLED=true
REDIS_PUBSUB_CHANNEL=webgui_updates

# Reporting
REPORT_EXPORT_PATH=/app/reports
PDF_GENERATOR_ENGINE=reportlab

# Scheduled Reports
SCHEDULED_REPORTS_ENABLED=false
SCHEDULED_REPORT_DAILY_TIME=09:00
SCHEDULED_REPORT_WEEKLY_DAY=monday
SCHEDULED_REPORT_WEEKLY_TIME=09:00
REDIS_SCHEDULER_DB=1
SCHEDULER_JOBSTORE=redis              # redis or database (requires DATABASE_ENABLED=true)
REPORT_WEBHOOK_URL=                  # Webhook URL for report delivery notifications
REPORT_WEBHOOK_SECRET=               # HMAC-SHA256 secret for webhook signatures
REPORT_SLACK_WEBHOOK_URL=            # Slack incoming webhook for report notifications
REPORT_DELIVERY_MAX_RETRIES=3        # Retry attempts for delivery channels

# Email delivery
REPORT_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=reports@example.com
REPORT_EMAIL_RECIPIENTS=

# WebSocket / Real-time
REALTIME_STREAM_MAX_LEN=1000         # Max messages per Redis Stream (message buffer)
REALTIME_STREAM_REPLAY_LIMIT=100     # Max messages replayed on reconnection

# Database (PostgreSQL)
DATABASE_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=agnostic
DB_POOL_SIZE=5                          # Connections kept open in pool
DB_MAX_OVERFLOW=10                      # Extra connections allowed when pool is full
DB_POOL_RECYCLE=3600                    # Recycle connections after N seconds
DB_POOL_TIMEOUT=30                      # Seconds to wait for a connection from pool

# Multi-Tenant
MULTI_TENANT_ENABLED=false
TENANT_DEFAULT_RATE_LIMIT=100        # Requests per minute per tenant

# AGNOS OS Integration
# Phase 1: LLM Gateway (see ADR-021)
AGNOS_LLM_GATEWAY_ENABLED=false
AGNOS_LLM_GATEWAY_URL=http://localhost:8088
AGNOS_LLM_GATEWAY_API_KEY=
AGNOS_LLM_GATEWAY_MODEL=default

# Phase 2: Agent HUD Registration (see ADR-022)
AGNOS_AGENT_REGISTRATION_ENABLED=false
AGNOS_AGENT_REGISTRY_URL=http://localhost:8090
AGNOS_AGENT_API_KEY=
AGNOS_HEARTBEAT_INTERVAL_SECONDS=30

# RPC inter-agent communication via daimon
AGNOS_RPC_ENABLED=false

# RAG knowledge grounding via daimon
AGNOS_RAG_ENABLED=false

# Screen capture and recording via daimon
AGNOS_SCREEN_ENABLED=false

# MCP tool registration with daimon
DAIMON_MCP_AUTO_REGISTER=false

# Path prefix for AGNOS REST APIs (hoosh/daimon use /v1)
AGNOS_PATH_PREFIX=/v1

# Phase 3: Deep Integration (ADR-028)
# Audit log forwarding to AGNOS cryptographic audit chain
AGNOS_AUDIT_ENABLED=false
AGNOS_AUDIT_URL=http://localhost:8090
AGNOS_AUDIT_API_KEY=
AGNOS_AUDIT_BATCH_SIZE=50
AGNOS_AUDIT_FLUSH_INTERVAL=5

# Agent persistent memory via AGNOS AgentMemoryStore
AGNOS_MEMORY_ENABLED=false
AGNOS_MEMORY_URL=http://localhost:8090
AGNOS_MEMORY_API_KEY=

# OpenTelemetry pipeline to AGNOS collector
AGNOS_OTEL_ENABLED=false
AGNOS_OTEL_ENDPOINT=http://localhost:4317
AGNOS_OTEL_SERVICE_NAME=agnostic-qa

# Reasoning trace submission to AGNOS dashboard
AGNOS_REASONING_ENABLED=false
AGNOS_REASONING_URL=http://localhost:8090
AGNOS_REASONING_API_KEY=

# Environment profile sync (dev/staging/prod auto-config)
# Set AGNOS_PROFILE to auto-configure: dev, staging, or prod
# Individual env vars above take precedence over profile defaults
AGNOS_PROFILE=
AGNOS_PROFILE_URL=http://localhost:8090
AGNOS_PROFILE_API_KEY=

# Capability advertisement
AGNOS_CAPABILITY_ADVERTISE_ENABLED=false

# AGNOS Dashboard Bridge (push agent status to unified dashboard)
AGNOS_DASHBOARD_BRIDGE_ENABLED=false
AGNOS_DASHBOARD_URL=http://localhost:8090
AGNOS_DASHBOARD_API_KEY=
AGNOS_DASHBOARD_PUSH_INTERVAL=30

# YEOMAN A2A Client (bidirectional communication with SecureYeoman)
YEOMAN_A2A_ENABLED=false
YEOMAN_A2A_URL=http://localhost:3001
YEOMAN_A2A_API_KEY=
YEOMAN_PEER_ID=secureyeoman

# YEOMAN MCP Auto-Registration (register AGNOSTIC as MCP server with SecureYeoman)
YEOMAN_MCP_AUTO_REGISTER=false
YEOMAN_MCP_URL=http://localhost:18789
YEOMAN_MCP_API_KEY=
AGNOSTIC_EXTERNAL_URL=http://localhost:8000

# YEOMAN JWT Authentication (accept SecureYeoman-issued JWTs)
YEOMAN_JWT_ENABLED=false
YEOMAN_JWT_ISSUER=secureyeoman
YEOMAN_JWT_PUBLIC_KEY=
YEOMAN_JWT_SECRET=
YEOMAN_JWT_AUDIENCE=agnostic-qa

# YEOMAN Webhooks (accept events from SecureYeoman extension hooks)
YEOMAN_WEBHOOKS_ENABLED=false
YEOMAN_WEBHOOK_SECRET=

# YEOMAN Outbound Event Push (push QA events to SecureYeoman)
YEOMAN_EVENT_PUSH_ENABLED=false
YEOMAN_EVENT_PUSH_URL=
YEOMAN_EVENT_PUSH_SECRET=

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Alerts / Notifications
ALERTS_ENABLED=false
ALERT_POLL_INTERVAL_SECONDS=30              # Health monitor poll interval
ALERT_COOLDOWN_SECONDS=300                  # Min seconds between repeated alerts
ALERT_WEBHOOK_URL=                          # Falls back to REPORT_WEBHOOK_URL
ALERT_WEBHOOK_SECRET=                       # Falls back to REPORT_WEBHOOK_SECRET
ALERT_SLACK_WEBHOOK_URL=                    # Falls back to REPORT_SLACK_WEBHOOK_URL
ALERT_EMAIL_RECIPIENTS=                     # Falls back to REPORT_EMAIL_RECIPIENTS
ALERT_DELIVERY_MAX_RETRIES=3

# Redis Connection Pool
REDIS_MAX_CONNECTIONS=50

# Advanced Features
ENABLE_SELF_HEALING=true
ENABLE_FUZZY_VERIFICATION=true
ENABLE_RISK_BASED_PRIORITIZATION=true
ENABLE_CONTEXT_AWARE_TESTING=true

# Phase 3: AGNOS Token Budget Integration
AGNOS_TOKEN_BUDGET_ENABLED=false
AGNOS_TOKEN_BUDGET_URL=http://localhost:8088
AGNOS_TOKEN_BUDGET_API_KEY=
AGNOS_TOKEN_BUDGET_POOL=agnostic-qa

# Model Selection
PRIMARY_MODEL_PROVIDER=openai
FALLBACK_MODEL_PROVIDERS=ollama

# Team Configuration
QA_TEAM_SIZE=standard
